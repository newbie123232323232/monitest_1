# Copy: cp .env.example .env rồi điền secret (file .env không commit)

# APP_ENV=development
APP_BASE_URL=http://localhost:5173
API_PUBLIC_URL=http://localhost:8000

# Khớp: user/db moni @ localhost:5432 — tạo bằng SQL trong ENV-CONVENTIONS.md
DATABASE_URL=postgresql+asyncpg://moni:moni_local_dev@localhost:5432/moni
# Beat không có biến riêng; cùng broker với worker.
# Local: redis://localhost:6379/0 | Redis Cloud: redis://default:PASSWORD@HOST:PORT/0 (hoặc rediss:// nếu bắt buộc TLS)
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

JWT_SECRET=
JWT_ACCESS_EXPIRE_MINUTES=15
JWT_REFRESH_EXPIRE_DAYS=14

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=

GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

EMAIL_VERIFY_TOKEN_EXPIRE_HOURS=48
