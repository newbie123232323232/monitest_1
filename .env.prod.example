# ========================
# Runtime mode
# ========================
APP_ENV=production
APP_BASE_URL=https://x3mphim.click
API_PUBLIC_URL=https://x3mphim.click

# ========================
# Database (kept same shape)
# ========================
POSTGRES_USER=moni
POSTGRES_PASSWORD=change_me_db_password
POSTGRES_DB=moni
DATABASE_URL=postgresql+asyncpg://moni:change_me_db_password@postgres:5432/moni

# ========================
# Redis/Celery (kept same shape)
# ========================
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# ========================
# Auth/JWT (must change)
# ========================
JWT_SECRET=replace_with_a_long_random_secret_at_least_32_chars
JWT_ACCESS_EXPIRE_MINUTES=15
JWT_REFRESH_EXPIRE_DAYS=14

# ========================
# SMTP (keep provider if already working)
# ========================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASSWORD=your_app_password
SMTP_FROM_EMAIL=your_email@example.com

# ========================
# OAuth (must match x3mphim.click)
# ========================
GOOGLE_OAUTH_CLIENT_ID=replace_me
GOOGLE_OAUTH_CLIENT_SECRET=replace_me
GOOGLE_OAUTH_REDIRECT_URI=https://x3mphim.click/api/v1/auth/google/callback

EMAIL_VERIFY_TOKEN_EXPIRE_HOURS=48

# ========================
# Image tags consumed by docker-compose.prod.yml
# ========================
BACKEND_IMAGE=ghcr.io/your-org-or-user/moni-backend:latest
FRONTEND_IMAGE=ghcr.io/your-org-or-user/moni-frontend:latest
